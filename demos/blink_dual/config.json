{
  "xsa": "blink.xsa",
  "plat_name": "blink",
  "fsbl":{
    "options":{
      "proc":{"proc_extra_compiler_flags": "-DUSE_AMP=1"}
    }
  },
  "cpu0":{
    "app_name": "cpu0_app",
    "template": "empty_application",
    "os": "freertos",
    "cmake":{
      "path_vars":{
        "BLINK_SRC": "src/cpu0",
        "AC7020C_COMMON_TASKS": "../../common/tasks"
      },
      "include": "${BLINK_SRC}/Cpu0.cmake"
    },
    "options":{
      "os":{"freertos_total_heap_size": 65536}
    }
  },
  "cpu1":{
    "app_name": "cpu1_app",
    "template": "hello_world",
    "os": "standalone",
    "cmake":{
      "path_vars":{
        "BLINK_SRC": "src/cpu1"
      },
      "include": "${BLINK_SRC}/Cpu1.cmake"
    }
  }
}
